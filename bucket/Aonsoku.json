{
  "version": "0.12.0",
  "description": "Modern desktop client for Navidrome/Subsonic servers.",
  "homepage": "https://github.com/victoralvesf/aonsoku",
  "license": "GPL-3.0-or-later",
  "architecture": {
    "64bit": {
      "url": "https://github.com/victoralvesf/aonsoku/releases/download/v0.12.0/Aonsoku-v0.12.0-win-x64.exe"
    }
  },
  "installer": {
    "script": [
      "# Extract NSIS installer with 7zip (requires 'scoop install 7zip')",
      "7z x \"$dir\\Aonsoku-v0.12.0-win-x64.exe\" -o\"$dir\" -y",
      "# Clean up installer files",
      "Remove-Item \"$dir\\[NSIS].nsi\", \"$dir\\[LICENSE].txt\", \"$dir\\uninstallerIcon.ico\" -Force -ErrorAction SilentlyContinue",
      "Remove-Item \"$dir\\$PLUGINSDIR\", \"$dir\\$R0\" -Recurse -Force -ErrorAction SilentlyContinue"
    ]
  },
  "bin": [
    "Aonsoku.exe"
  ],
  "shortcuts": [
    [
      "Aonsoku.exe",
      "Aonsoku"
    ]
  ],
  "checkver": {
    "github": "https://github.com/victoralvesf/aonsoku"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/victoralvesf/aonsoku/releases/download/v$version/Aonsoku-v$version-win-x64.exe"
      }
    }
  }
}
