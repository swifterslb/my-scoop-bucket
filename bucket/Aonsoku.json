{
  "version": "0.12.0",
  "description": "Modern desktop client for Navidrome/Subsonic servers.",
  "homepage": "https://github.com/victoralvesf/aonsoku",
  "license": "GPL-3.0-or-later",
  "architecture": {
    "64bit": {
      "url": "https://github.com/victoralvesf/aonsoku/releases/download/v0.12.0/Aonsoku-v0.12.0-win-x64.exe"
    }
  },
  "pre_install": [
    "# Run NSIS installer silently to $dir",
    "\"$dir\\Aonsoku-v0.12.0-win-x64.exe\" /S /D=\"$dir\""
  ],
  "installer": {
    "script": [
      "# Clean up installer exe after silent install",
      "Remove-Item \"$dir\\Aonsoku-v0.12.0-win-x64.exe\" -Force -ErrorAction SilentlyContinue"
    ]
  },
  "bin": [
    "Aonsoku.exe"
  ],
  "shortcuts": [
    [
      "Aonsoku.exe",
      "Aonsoku"
    ]
  ],
  "checkver": {
    "github": "https://github.com/victoralvesf/aonsoku"
  },
  "autoupdate": {
    "architecture": {
      "64bit": {
        "url": "https://github.com/victoralvesf/aonsoku/releases/download/v$version/Aonsoku-v$version-win-x64.exe"
      }
    }
  }
}
